# Copy to .env and fill in. .env is gitignored — never commit real values.

# Kalshi API (generate in Kalshi: Settings -> API Keys)
KALSHI_API_KEY_ID=your-api-key-uuid-here
KALSHI_PRIVATE_KEY_PATH=./secrets/kalshi_key.pem

# Trading mode: paper = log only, place no orders | live = place real orders
NESTOR_ENV=paper

# Sizing (USD)
NESTOR_STAKE_USD=10
NESTOR_MAX_DAILY_USD=80

# Optional alerting (Telegram/Slack/Discord webhook). Blank = no alerts.
ALERT_WEBHOOK_URL=
