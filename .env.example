# Copy to .env and fill in. .env is gitignored — never commit real values.

# Kalshi API (generate in Kalshi: Settings -> API Keys). Only needed for live.
KALSHI_API_KEY_ID=your-api-key-uuid-here
KALSHI_PRIVATE_KEY_PATH=./secrets/kalshi_key.pem

# Trading mode: paper = log + simulate fills, no orders | live = place real orders
NESTOR_ENV=paper

# Risk layer
NESTOR_BANKROLL=1000            # starting equity (used only on first run / fresh state)
NESTOR_STATE_PATH=data/state.json
NESTOR_FRACTION=0.05            # fraction of bankroll per trade (fraction-sized sleeves)
NESTOR_CLUSTER_CAP=0.15         # max at-risk in one correlation cluster (fraction of bankroll)
NESTOR_STAKE_USD=10             # flat $ per trade (flat-sized sleeves: weather)
NESTOR_MAX_DAILY_USD=80         # daily flat-budget cap
NESTOR_MAX_DRAWDOWN=0.30        # halt if drawdown from peak exceeds this
NESTOR_DAILY_LOSS_LIMIT=0.15    # halt if today's realized loss exceeds this * peak

# Optional alerting webhook (Telegram/Slack/Discord). Blank = no alerts.
ALERT_WEBHOOK_URL=
